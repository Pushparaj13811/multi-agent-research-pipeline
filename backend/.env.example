# LLM API keys are managed per-user via the Settings page (encrypted in DB).
# No server-level LLM keys needed.

# Search Providers (server-managed)
TAVILY_API_KEY=tvly-...
SERPER_API_KEY=...

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_agent

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=multi-agent-research

# OpenTelemetry (optional)
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO

# Cost Guardrails
MAX_TOKENS_PER_RUN=100000
MAX_COST_PER_RUN=1.0
BUDGET_WARNING_THRESHOLD=0.8

# Auth
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440
# CRITICAL: Set this before storing any API keys. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DO NOT CHANGE after keys are stored - existing keys will become unrecoverable
ENCRYPTION_KEY=

# App
CORS_ORIGINS=http://localhost:5173
