# ============================================
# Multi-Agent Research Pipeline — Environment
# Copy this to .env and fill in your values
# ============================================

# LLM API keys are managed per-user via the Settings page (encrypted in DB).
# No server-level LLM keys needed.

# ----- Search Providers (server-managed) -----
TAVILY_API_KEY=tvly-...
SERPER_API_KEY=...

# ----- Database -----
# Docker Compose overrides this internally. Set here only for local dev.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/research_agent
POSTGRES_PASSWORD=postgres

# ----- LangSmith -----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=multi-agent-research

# ----- OpenTelemetry (optional) -----
# Start Jaeger with: docker compose --profile otel up
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ----- Redis -----
# Docker Compose overrides this internally.
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Cost Guardrails -----
MAX_TOKENS_PER_RUN=100000
MAX_COST_PER_RUN=1.0
BUDGET_WARNING_THRESHOLD=0.8

# ----- Auth -----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# CRITICAL: Generate BEFORE storing any API keys:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DO NOT CHANGE after keys are stored — existing keys become unrecoverable
ENCRYPTION_KEY=

# ----- App -----
CORS_ORIGINS=http://localhost
WORKERS=2

# ----- Docker Compose Ports (optional overrides) -----
# FRONTEND_PORT=80
# BACKEND_PORT=8000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
